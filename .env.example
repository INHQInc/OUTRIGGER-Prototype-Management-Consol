# Copy to .env.local and fill in. Never commit .env.local.

# --- Capture ---
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Auth ---
# Random secret that signs 365-day session cookies (e.g. `openssl rand -base64 48`)
AUTH_SECRET=
# Comma-separated emails allowed to admin-login
ADMIN_EMAILS=admin@outrigger.local
# Master secret for admin sign-in
ADMIN_LOGIN_SECRET=changeme-local-dev

# --- Hosted persistence (optional locally; required for hosted auth/bindings) ---
# Neon Postgres connection string. Absent => JSON store under .data/ (local only).
DATABASE_URL=

# --- Optimizely (experiment draft-push) ---
# Scoped service-account Personal Access Token
OPTIMIZELY_API_TOKEN=
# Prep sandbox 24138040550 (prove here first), Prod 21089662478
OPTIMIZELY_PROJECT_ID=24138040550
